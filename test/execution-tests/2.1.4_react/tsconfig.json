{
	"compilerOptions": {
		"jsx": "react",
		"target": "es6",
		"noImplicitAny": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noEmitOnError": true,
		"removeComments": false,
		"preserveConstEnums": true,
		"sourceMap": true,
		"skipLibCheck": true,
		"types": [
			"jasmine"
		]
	}
}
